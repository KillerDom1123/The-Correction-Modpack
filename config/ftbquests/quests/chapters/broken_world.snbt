	quests: [
		{
			description: [
				"&8[ FIELD SURVEY — ENTRY 001 ]&r"
				""
				"&7Someone lived here before us. The evidence is not subtle: foundations, tools, walls that were built to a plan. Then everyone left. All at once, as far as I can tell.&r"
				""
				"&7There is no sign of a battle. No bodies. No fire. The structures were not destroyed.&r"
				""
				"&6\"The world is not destroyed. It is interrupted.\"&r"
				""
				"&8Objective: locate one of their abandoned places and stand inside it. See it for yourself before you form an opinion.&r"
			]
			icon: "minecraft:cracked_stone_bricks"
			id: "7A01000000000101"
			rewards: [
				{ id: "7A01000000000301", type: "xp", xp: 15 }
				{ id: "7A01000000000302", item: "sophisticatedbackpacks:backpack", type: "item" }
				{ id: "7A01000000000303", item: "explorerscompass:explorerscompass", type: "item" }
				{ id: "7A01000000000304", item: "naturescompass:naturescompass", type: "item" }
				{ count: 4, id: "7A01000000000305", item: "farmersdelight:hamburger", type: "item" }
				{ count: 16, id: "7A01000000000306", item: "minecraft:torch", type: "item" }
			]
			shape: "hexagon"
			size: 1.5d
			subtitle: "A World Left Behind"
			tasks: [{
				id: "7A01000000000201"
				title: "Stand inside a place someone abandoned"
				type: "checkmark"
			}]
			x: 0.0d
			y: 0.0d
		}
		{
			dependencies: ["7A01000000000101"]
			description: [
				"&8[ FIELD SURVEY — ENTRY 007 ]&r"
				""
				"&7I have started keeping a count. Biomes. Structures. Anything underground. The pattern only appears once you have enough entries to compare.&r"
				""
				"&6\"The further you travel, the more evidence you find that this was once a connected world.\"&r"
				""
				"&8Objective: survey the land. Cover ground. Write down what you find.&r"
			]
			id: "7A01000000000102"
			rewards: [
				{ id: "7A01000000000307", type: "xp", xp: 25 }
				{ id: "7A01000000000308", item: "waystones:waystone", type: "item" }
				{ count: 2, id: "7A01000000000309", item: "waystones:warp_scroll", type: "item" }
