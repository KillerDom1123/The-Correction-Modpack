				{ id: "7A01000000000203", title: "Log 3 generated structures", type: "checkmark" }
				{ id: "7A01000000000204", title: "Log 1 underground location", type: "checkmark" }
			]
			x: 2.5d
			y: 0.0d
		}
		{
			dependencies: ["7A01000000000102"]
			description: [
				"&8[ RECOVERED NOTE — AUTHOR UNKNOWN ]&r"
				""
				"&7This page was found pinned inside a survey tent. The handwriting deteriorates toward the end.&r"
				""
				"&7\"Early explorers reported sounds and movements outside their camps.\"&r"
				"&7\"Most assumed exhaustion.\"&r"
				""
				"&8I have decided to test it. Five nights out here. I will sleep as little as I can stand and record what I hear.&r"
				""
				"&8[ remainder of page illegible ]&r"
			]
			hide_until_deps_complete: true
