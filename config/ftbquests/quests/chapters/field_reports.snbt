	quests: [
		{
			description: [
				"&8[ HORROR PATH — \"SOMETHING SURVIVED.\" ]&r"
				""
				"&7This is not a hunt. I am not here to kill anything. I am here to record what is still moving in the places that should be empty.&r"
				""
				"&8Objective: go into the dark places — deep caves, old structures, forests that grew back wrong. Take a light. Take a camera. Do not engage.&r"
			]
			id: "7A05000000000101"
			rewards: [
				{ id: "7A05000000000301", type: "xp", xp: 20 }
				{ id: "7A05000000000302", item: "camerapture:camera", type: "item" }
				{ count: 16, id: "7A05000000000303", item: "minecraft:paper", type: "item" }
