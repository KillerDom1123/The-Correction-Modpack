		{
			dependencies: ["7A05000000000101"]
			description: [
				"&8[ FIELD REPORT — ONGOING ]&r"
				""
				"&7I stayed out. No claimed ground, no walls that mean anything. Ten nights. By the fourth I was certain I was not being hunted.&r"
				""
				"&7I was being observed.&r"
				""
				"&7\"Something has noticed the return of civilisation.\"&r"
			]
			id: "7A05000000000106"
			rewards: [
				{ id: "7A05000000000317", type: "xp", xp: 30 }
				{ id: "7A05000000000318", item: "artifacts:running_shoes", type: "item" }
				{ id: "7A05000000000319", item: "comforts:sleeping_bag_red", type: "item" }
				{ count: 4, id: "7A0500000000031A", item: "farmersdelight:vegetable_soup", type: "item" }
			]
			subtitle: "The Watchers"
