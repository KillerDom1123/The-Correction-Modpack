				{ count: 6, id: "7A05000000000306", item: "farmersdelight:cooked_bacon", type: "item" }
			]
			shape: "hexagon"
			size: 1.5d
			subtitle: "Into The Dark"
			tasks: [{
				id: "7A05000000000201"
				title: "Venture into deep caves, ancient structures and dense forests"
				type: "checkmark"
			}]
			x: 0.0d
			y: 0.0d
		}
		{
			dependencies: ["7A05000000000101"]
			description: [
				"&8[ METHODOLOGY ]&r"
				""
				"&7If I write down what I see, no one believes me. So I photograph it instead. A picture is harder to argue with.&r"
				""
				"&7\"The Old Civilisation documented everything.\"&r"
				"&7\"Perhaps they were trying to understand.\"&r"
				""
				"&8Objective: photograph ruins, unusual areas, and anything that should not be happening.&r"
			]
			id: "7A05000000000102"
			rewards: [
				{ id: "7A05000000000307", type: "xp", xp: 25 }
				{ id: "7A05000000000308", item: "camerapture:album", type: "item" }
				{ count: 16, id: "7A05000000000309", item: "minecraft:paper", type: "item" }
				{ id: "7A0500000000030A", item: "minecraft:spyglass", type: "item" }
			]
			subtitle: "Observation"
			tasks: [
				{ count: 3, id: "7A05000000000202", item: "camerapture:picture", type: "item" }
			]
			x: 2.5d
			y: 0.0d
		}
		{
			dependencies: ["7A05000000000101"]
			description: [
				"&8[ FIELD REPORT — CORROBORATED ]&r"
				""
				"&7Several expedition notes describe the same phenomenon in the same woods. Independent authors. Identical wording in places.&r"
				""
				"&7\"The environment seemed aware.\"&r"
				""
				"&8I do not know what that means yet. I only know they all wrote it down before they stopped writing.&r"
			]
			id: "7A05000000000103"
			rewards: [
				{ id: "7A0500000000030B", type: "xp", xp: 25 }
				{ id: "7A0500000000030C", item: "comforts:sleeping_bag_red", type: "item" }
				{ count: 4, id: "7A0500000000030D", item: "farmersdelight:mixed_salad", type: "item" }
				{ count: 16, id: "7A0500000000030E", item: "minecraft:torch", type: "item" }
			]
			subtitle: "The Forest Does Not Forget"
			tasks: [{
				id: "7A05000000000203"
				title: "Reach the Creeping Woods and record what you find"
				type: "checkmark"
			}]
			x: 4.5d
			y: -1.5d
		}
		{
			dependencies: ["7A05000000000101"]
			description: [
				"&8[ RECOVERED WARNING — OLDEST ON RECORD ]&r"
				""
				"&7The deeper the site, the older the warning. And the oldest warnings we have all point downward.&r"
				""
				"&7\"The oldest warnings concern what exists beneath the surface.\"&r"
				""
				"&8Objective: descend. Alex's Caves, the deep dark, anywhere the light has never reached. Be sure something is not descending with you.&r"
			]
			id: "7A05000000000104"
			rewards: [
				{ id: "7A0500000000030F", type: "xp", xp: 25 }
				{ id: "7A05000000000310", item: "artifacts:obsidian_skull", type: "item" }
