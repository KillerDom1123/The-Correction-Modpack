		{
			dependencies: ["7A05000000000101"]
			description: [
				"&8[ FIELD REPORT — IT WEARS FACES ]&r"
				""
				"&7Witnesses describe a thing that is almost right. It reproduces a shape, a voice, a habit — and gets one detail wrong, always. Whatever is left behind after it is dealt with does not stay one shape for long.&r"
				""
				"&8Objective: recover a Distorted Replica. However you come by it.&r"
			]
			hide_dependency_lines: true
			icon: "oldcivilisation:distorted_replica"
			id: "7A05000000000107"
			optional: true
			rewards: [
