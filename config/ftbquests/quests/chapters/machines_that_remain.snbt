		{
			dependencies: ["7A02000000000102"]
			description: [
				"&8[ SITE REPORT — SECOND GENERATION ]&r"
				""
				"&7The simple machines were only the beginning. The next layer of their workshops ran on brass, and on a small, precise clockwork core I keep finding intact.&r"
				""
				"&8Objective: reach the brass age — crushing wheels, a mechanical crafter, a deployer. Press your first Precision Mechanism.&r"
			]
			id: "7A02000000000108"
			rewards: [
				{ id: "7A0200000000031D", type: "xp", xp: 25 }
				{ count: 4, id: "7A0200000000031E", item: "create:precision_mechanism", type: "item" }
				{ count: 8, id: "7A0200000000031F", item: "create:brass_ingot", type: "item" }
			]
			subtitle: "Brass and Precision"
			tasks: [
				{ id: "7A02000000000215", item: "create:crushing_wheel", type: "item" }
				{ id: "7A02000000000216", item: "create:mechanical_crafter", type: "item" }
