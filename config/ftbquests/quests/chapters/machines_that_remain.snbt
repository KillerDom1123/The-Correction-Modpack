			]
			x: 5.0d
			y: 0.0d
		}
		{
			dependencies: ["7A02000000000101"]
			description: [
				"&8[ SURVEY NOTE — TRANSIT LINES ]&r"
				""
				"&7The rails run everywhere. They connect sites that are days apart on foot. Then, at some point, the network simply stopped being used.&r"
				""
				"&7\"The world was connected once.\"&r"
				"&7\"Something made connection unnecessary.\"&r"
			]
			id: "7A02000000000104"
			rewards: [
				{ id: "7A0200000000030F", type: "xp", xp: 20 }
				{ count: 32, id: "7A02000000000310", item: "minecraft:rail", type: "item" }
				{ count: 8, id: "7A02000000000311", item: "minecraft:powered_rail", type: "item" }
				{ count: 4, id: "7A02000000000312", item: "create:railway_casing", type: "item" }
				{ count: 2, id: "7A02000000000313", item: "waystones:warp_scroll", type: "item" }
			]
			subtitle: "The Rail Network"
			tasks: [
				{ id: "7A0200000000020D", item: "create:railway_casing", type: "item" }
				{ id: "7A0200000000020E", item: "create:track", type: "item" }
				{ id: "7A0200000000020F", item: "create:track_station", type: "item" }
			]
			x: 2.5d
			y: 2.0d
		}
		{
			dependencies: ["7A02000000000103"]
			description: [
				"&8[ OPEN QUESTION — POWER ]&r"
				""
				"&7It does not matter which method you use — rotational, electrical, pressurised. They all lead to the same question, and I cannot answer it.&r"
				""
				"&7\"The Old Civilisation mastered energy.\"&r"
				"&7\"The question is why they needed so much.\"&r"
				""
				"&8Objective: get a power source of any discipline running. The method is yours to choose. It always was.&r"
			]
			icon: "immersiveengineering:capacitor_lv"
			id: "7A02000000000105"
			rewards: [
				{ id: "7A02000000000314", type: "xp", xp: 25 }
				{ count: 4, id: "7A02000000000315", item: "create:electron_tube", type: "item" }
				{ id: "7A02000000000316", item: "mekanism:energy_tablet", type: "item" }
			]
			subtitle: "The Power Question"
			tasks: [{
				id: "7A02000000000210"
				title: "Run a working power source (Create / Immersive / Pneumatic — your choice)"
				type: "checkmark"
			}]
			x: 5.0d
			y: 2.0d
		}
		{
			dependencies: ["7A02000000000105"]
			description: [
				"&8[ CROSS-REFERENCE — TROUBLING ]&r"
				""
				"&7I built these to modern designs. Then I found the same machines — the exact same layouts — in a facility that predates everything we know.&r"
				""
				"&7\"Several abandoned facilities contain machines almost identical to these.\"&r"
				""
				"&8We are not inventing. We are repeating.&r"
			]
			id: "7A02000000000106"
			rewards: [
				{ id: "7A02000000000317", type: "xp", xp: 30 }
				{ count: 16, id: "7A02000000000318", item: "mekanism:ingot_osmium", type: "item" }
