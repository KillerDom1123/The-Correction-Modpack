		}
		{
			dependencies: ["7A02000000000106"]
			description: [
				"&8[ RECOVERED DOCUMENT — HEAVILY REDACTED ]&r"
				""
				"&7\"Records repeatedly mention a final energy project.\"&r"
				"&7\"The details are missing.\"&r"
				""
				"&8Every reference to it has been deliberately cut from the archive. The redactions are clean. Someone did not want this reconstructed.&r"
				""
				"&8I am reconstructing it anyway. I want to see what they were so afraid of.&r"
				""
				"&8[ cause of abandonment: unknown ]&r"
			]
			hide: true
			hide_dependency_lines: true
