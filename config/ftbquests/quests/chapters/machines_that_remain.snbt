			]
			x: 0.0d
			y: 0.0d
		}
		{
			dependencies: ["7A02000000000101"]
			description: [
				"&8[ SITE REPORT — RECURRING PATTERN ]&r"
				""
				"&7Every facility I catalogue shows the same thing. Nothing was carried by hand. Belts, chutes, arms — the material moved itself.&r"
				""
				"&7\"Automation was everywhere.\"&r"
				"&7\"The Old Civilisation did not work harder.\"&r"
				"&7\"It made the world work for it.\"&r"
			]
			id: "7A02000000000102"
			rewards: [
				{ id: "7A02000000000305", type: "xp", xp: 20 }
				{ count: 4, id: "7A02000000000306", item: "create:brass_casing", type: "item" }
				{ id: "7A02000000000307", item: "sophisticatedbackpacks:backpack", type: "item" }
				{ id: "7A02000000000308", item: "sophisticatedbackpacks:pickup_upgrade", type: "item" }
				{ id: "7A02000000000309", item: "sophisticatedbackpacks:magnet_upgrade", type: "item" }
			]
			subtitle: "A Moving World"
			tasks: [
				{ id: "7A02000000000205", item: "create:belt_connector", type: "item" }
				{ id: "7A02000000000206", item: "create:andesite_funnel", type: "item" }
				{ id: "7A02000000000207", item: "create:chute", type: "item" }
				{ id: "7A02000000000208", item: "create:mechanical_arm", type: "item" }
			]
			x: 2.5d
			y: 0.0d
		}
		{
			dependencies: ["7A02000000000102"]
			description: [
				"&8[ SITE REPORT — INDUSTRIAL ZONE ]&r"
				""
				"&7These are heavier than the Create-pattern machines. Furnaces the size of houses. Storage for energy I do not fully understand.&r"
				""
				"&7\"Industrial facilities remain scattered across the world.\"&r"
				"&7\"Almost all were abandoned simultaneously.\"&r"
				""
				"&8Whatever made them leave, they did not stop to shut anything down.&r"
			]
			id: "7A02000000000103"
			rewards: [
				{ id: "7A0200000000030A", type: "xp", xp: 30 }
				{ id: "7A0200000000030B", item: "immersiveengineering:manual", type: "item" }
				{ id: "7A0200000000030C", item: "immersiveengineering:hammer", type: "item" }
				{ count: 16, id: "7A0200000000030D", item: "immersiveengineering:ingot_steel", type: "item" }
				{ count: 8, id: "7A0200000000030E", item: "immersiveengineering:plate_steel", type: "item" }
			]
			subtitle: "Industrial Foundations"
			tasks: [
				{ id: "7A02000000000209", item: "immersiveengineering:cokebrick", type: "item" }
				{ id: "7A0200000000020A", item: "immersiveengineering:blastbrick", type: "item" }
