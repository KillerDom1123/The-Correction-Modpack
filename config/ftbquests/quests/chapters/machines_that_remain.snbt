	quests: [
		{
			description: [
				"&8[ ENGINEERING PATH — \"THE PREVIOUS AGE\" ]&r"
				""
				"&7If we understand what they built, we understand what happened. That is the theory, at least.&r"
				""
				"&7\"The earliest machines recovered were not weapons.\"&r"
				"&7\"They were tools.\"&r"
				""
				"&8Objective: reconstruct the simplest of their machines from recovered schematics.&r"
			]
			id: "7A02000000000101"
			rewards: [
				{ id: "7A02000000000301", type: "xp", xp: 20 }
				{ count: 16, id: "7A02000000000302", item: "create:andesite_alloy", type: "item" }
				{ count: 8, id: "7A02000000000303", item: "create:cogwheel", type: "item" }
				{ count: 2, id: "7A02000000000304", item: "create:precision_mechanism", type: "item" }
			]
			shape: "hexagon"
			size: 1.5d
			subtitle: "Simple Machines"
			tasks: [
				{ id: "7A02000000000201", item: "create:water_wheel", type: "item" }
				{ id: "7A02000000000202", item: "create:mechanical_press", type: "item" }
				{ id: "7A02000000000203", item: "create:encased_fan", type: "item" }
