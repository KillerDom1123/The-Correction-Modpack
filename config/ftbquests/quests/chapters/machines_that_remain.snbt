		{
			dependencies: ["7A02000000000108"]
			description: [
				"&8[ CROSS-REFERENCE — TWO ENERGIES ]&r"
				""
				"&7Their rotational machines fed something else: a current, carried on wire. Where rotation ended, electricity began. The two systems were never separate to them.&r"
				""
				"&8Objective: bridge rotation to current — an electric motor, an alternator, an accumulator to hold what you make.&r"
			]
			icon: "createaddition:electric_motor"
			id: "7A02000000000109"
			rewards: [
				{ id: "7A02000000000320", type: "xp", xp: 25 }
				{ count: 2, id: "7A02000000000321", item: "createaddition:capacitor", type: "item" }
			]
			subtitle: "Captured Lightning"
			tasks: [
