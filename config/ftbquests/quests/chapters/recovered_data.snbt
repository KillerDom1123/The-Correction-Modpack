		{
			dependencies: ["7A04000000000103"]
			description: [
				"&8[ RECOVERED FRAGMENT #12 ]&r"
				""
				"&7The following document was recovered from an unknown facility. Large portions are corrupted.&r"
				""
				"&8\"...the timeline is continuous until the final period...\"&r"
				"&8\"...after which no entries exist...\"&r"
				"&8\"...the gap is not damage. the gap is uniform...\"&r"
				""
				"&7\"The final records were not lost.\"&r"
				"&7\"They were deliberately removed.\"&r"
				""
				"&8Cause unknown.&r"
			]
