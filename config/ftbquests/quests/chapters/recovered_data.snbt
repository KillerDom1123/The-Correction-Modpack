		{
			description: [
				"&8[ ARCHIVE PATH — \"THE TRUTH EXISTS. SOMEONE REMOVED IT.\" ]&r"
				""
				"&7The old systems were not built to hold materials. They were built to hold information — and to keep holding it long after their builders were gone.&r"
				""
				"&7\"The old systems were designed to preserve information.\"&r"
				""
				"&8Objective: bring one of these systems back online. Then we can start reading.&r"
			]
			id: "7A04000000000101"
			rewards: [
				{ id: "7A04000000000301", type: "xp", xp: 25 }
