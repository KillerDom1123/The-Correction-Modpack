			description: [
				"&8[ ASSEMBLED FROM MULTIPLE FRAGMENTS ]&r"
				""
				"&7I have collected enough of the removed records to reconstruct their final months. It does not read like the end of a war.&r"
				""
				"&7It reads like preparation.&r"
				""
				"&7\"They did not fight.\"&r"
				"&7\"They prepared.\"&r"
				""
				"&8Prepared for what? The next fragments only ever point upward.&r"
			]
			id: "7A07000000000101"
