		{
			dependencies: ["7A07000000000101"]
			description: [
				"&8[ RECONSTRUCTED PROJECT — DESIGNATION: HS-LGTFO ]&r"
				""
				"&7The official name is gone. Only this fragment of a designation survives, and it does not read like something a government chose. It reads like something desperate engineers scrawled on the side of the thing.&r"
				""
				"&8The purpose was not to conquer. Not to fight. To leave.&r"
				""
				"&8Objective: build what they built. A rocket. A suit that survives the outside. Fuel enough to reach it.&r"
			]
			icon: "ad_astra:space_suit"
			id: "7A07000000000102"
			rewards: [
				{ id: "7A07000000000305", type: "xp", xp: 40 }
