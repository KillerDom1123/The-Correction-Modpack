		}
		{
			dependencies: ["7A07000000000102"]
			description: [
				"&8[ FOLLOWING THEIR ROUTE ]&r"
				""
				"&7The records list where they went, in order. I am retracing it. The Moon. Then Mars. Then the stations they left in orbit, still turning, still empty.&r"
				""
				"&8Every site tells the same story the last one did. They were here. They did not stay.&r"
			]
			icon: "ad_astra:tier_2_rocket"
			id: "7A07000000000103"
			rewards: [
				{ id: "7A07000000000309", type: "xp", xp: 50 }
				{ count: 4, id: "7A0700000000030A", item: "ad_astra:cryo_fuel_bucket", type: "item" }
				{ count: 8, id: "7A0700000000030B", item: "ad_astra:ostrum_ingot", type: "item" }
				{ count: 4, id: "7A0700000000030C", item: "ad_astra:calorite_ingot", type: "item" }
			]
			subtitle: "Following Their Path"
