				{ id: "7A03000000000207", item: "occultism:chalk_white", type: "item" }
			]
			x: 5.0d
			y: 0.0d
		}
		{
			dependencies: ["7A03000000000101"]
			description: [
				"&8[ FIELD NOTE — FOLK PRACTICE ]&r"
				""
				"&7This knowledge survived differently. Not in archives — in habit, in ritual, passed hand to hand by people who never wrote it down.&r"
				""
				"&7\"Some knowledge survived because people were afraid to forget it.\"&r"
			]
			id: "7A03000000000104"
			rewards: [
				{ id: "7A0300000000030D", type: "xp", xp: 25 }
				{ count: 4, id: "7A0300000000030E", item: "supplementaries:jar", type: "item" }
