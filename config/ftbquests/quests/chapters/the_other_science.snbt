		{
			description: [
				"&8[ ARCANE PATH — \"THE FALLEN\" ]&r"
				""
				"&7Perhaps the machines were never the cause. Some of the recovered sites have nothing mechanical in them at all — only symbols, and the residue of something that was studied very seriously.&r"
				""
				"&7\"The Old Civilisation had multiple methods of discovery.\"&r"
				""
				"&8They did not separate science from magic. To them these were only different ways of reading the same reality.&r"
			]
			id: "7A03000000000101"
			rewards: [
				{ id: "7A03000000000301", type: "xp", xp: 20 }
				{ count: 12, id: "7A03000000000302", item: "ars_nouveau:source_gem", type: "item" }
				{ count: 8, id: "7A03000000000303", item: "minecraft:amethyst_shard", type: "item" }
			]
			shape: "hexagon"
			size: 1.5d
			subtitle: "Old Symbols"
