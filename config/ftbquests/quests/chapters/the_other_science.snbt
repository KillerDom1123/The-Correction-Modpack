				{ id: "7A03000000000203", item: "ars_nouveau:imbuement_chamber", type: "item" }
			]
			x: 0.0d
			y: 0.0d
		}
		{
			dependencies: ["7A03000000000101"]
			description: [
				"&8[ RESEARCH LOG — SOURCE STUDIES ]&r"
				""
				"&7It behaves like energy, but it responds to intent. I can measure it, store it, spend it. I cannot explain it.&r"
				""
				"&7\"Some researchers believed reality was not broken.\"&r"
				"&7\"Only misunderstood.\"&r"
			]
			id: "7A03000000000102"
			rewards: [
				{ id: "7A03000000000304", type: "xp", xp: 25 }
				{ count: 8, id: "7A03000000000305", item: "ars_nouveau:source_gem", type: "item" }
				{ id: "7A03000000000306", item: "irons_spellbooks:wimpy_spell_book", type: "item" }
				{ count: 2, id: "7A03000000000307", item: "irons_spellbooks:scroll", type: "item" }
				{ count: 4, id: "7A03000000000308", item: "irons_spellbooks:arcane_ingot", type: "item" }
			]
			subtitle: "A Different Kind of Power"
			tasks: [
				{ id: "7A03000000000204", item: "ars_nouveau:enchanting_apparatus", type: "item" }
				{ id: "7A03000000000205", title: "Generate Source and cast a spell of your own making", type: "checkmark" }
			]
			x: 2.5d
			y: 0.0d
		}
		{
			dependencies: ["7A03000000000102"]
			description: [
				"&8[ RECOVERED DOCUMENT — RITUAL STUDIES ]&r"
				""
				"&7They did not build a workforce. They asked for one, and something answered.&r"
				""
				"&7\"The spirits answered.\"&r"
				"&7\"The records do not explain why.\"&r"
				""
				"&8The transcripts are one-sided. We only ever recorded our half of the conversation.&r"
			]
			id: "7A03000000000103"
			rewards: [
				{ id: "7A03000000000309", type: "xp", xp: 25 }
				{ count: 8, id: "7A0300000000030A", item: "occultism:datura", type: "item" }
