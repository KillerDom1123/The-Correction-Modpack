		{
			dependencies: ["7A03000000000103", "7A03000000000104"]
			dependency_requirement: "one_completed"
			description: [
				"&8[ RECOVERED DOCUMENT — SEALED ]&r"
				""
				"&7This line of research was closed before the end. Not lost to the disaster — closed on purpose, while there was still someone left to close it.&r"
				""
				"&7\"Some discoveries were abandoned before the world ended.\"&r"
				""
				"&8They stopped themselves. That is what worries me.&r"
			]
			id: "7A03000000000105"
			rewards: [
				{ id: "7A03000000000311", type: "xp", xp: 30 }
